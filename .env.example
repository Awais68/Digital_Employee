# =============================================================================
# Digital Employee - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!

# =============================================================================
# LLM Configuration (Required)
# =============================================================================
OPENAI_API_KEY=your-openai-api-key-here
LITELLM_API_KEY=your-litellm-api-key-here
LITELLM_MODEL=gpt-4

# =============================================================================
# Sender Information
# =============================================================================
SENDER_NAME=Digital Employee
SENDER_EMAIL=your-email@gmail.com
SENDER_TITLE=CTO / AI Engineer

# =============================================================================
# Gmail Configuration
# =============================================================================
# Place credentials.json in ./credentials/ directory
# Token will be auto-generated in ./tokens/ directory

# =============================================================================
# WhatsApp/Twilio Configuration (Optional)
# =============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# =============================================================================
# LinkedIn Configuration (Optional)
# =============================================================================
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_URN=your-linkedin-urn

# =============================================================================
# Odoo 19 Configuration (Gold Tier MCP Server)
# =============================================================================
ODOO_URL=http://localhost:8069
ODOO_DB=digital_fte
ODOO_USERNAME=admin
ODOO_PASSWORD=your-odoo-password-here

# Odoo Master Password (for database management operations)
# Found in odoo.conf as 'admin_passwd'
ODOO_MASTER_PASSWORD=your-master-password-here

# =============================================================================
# Email MCP Configuration
# =============================================================================
DRY_RUN=false
MAX_ATTACHMENT_SIZE=10485760

# =============================================================================
# Scheduling Configuration
# =============================================================================
CRON_SCHEDULE=*/30 * * * *
GMAIL_WATCH_INTERVAL=60

# =============================================================================
# Volume Path Overrides (Optional)
# =============================================================================
# CREDENTIALS_PATH=./credentials
# TOKENS_PATH=./tokens
# LOGS_PATH=./Logs
# METRICS_PATH=./Metrics
# DONE_PATH=./Done
# NEEDS_ACTION_PATH=./Needs_Action
# PENDING_APPROVAL_PATH=./Pending_Approval
# APPROVED_PATH=./Approved
# REJECTED_PATH=./Rejected
# PLANS_PATH=./Plans
# EMAIL_TEMPLATES_PATH=./Email_Templates

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
